# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/premed_election

# Server
PORT=5000
LOG_LEVEL=info

# Client (for CORS)
CLIENT_URL=http://localhost:5173

# OCR Configuration
OCR_MAX_CONCURRENCY=2

# Admin & Developer Access Keys (for dev/reset endpoints)
ADMIN_RESET_KEY=dev-reset-key
DEVELOPER_KEY=dev-key

# Super admin seed credentials (override defaults in production)
ADMIN_USERNAME=superadmin
ADMIN_PASSWORD=change-me-in-production

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# PWA Push Notifications (VAPID Keys)
# Generate VAPID keys with: npm run generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@premed-election.local

# Environment
NODE_ENV=development
